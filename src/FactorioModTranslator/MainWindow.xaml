<Window x:Class="FactorioModTranslator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:views="clr-namespace:FactorioModTranslator.Views"
        mc:Ignorable="d"
        Title="{Binding AppTitle}" Height="700" Width="1000">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="{StaticResource SurfaceBrush}" Padding="20,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding AppTitle}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                <Button Content="🌐" Command="{Binding SwitchLanguageCommand}" Margin="20,0,0,0" Width="40" Background="Transparent" Foreground="{StaticResource TextBrush}"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="10">
            <TabItem Header="Mod Selection">
                <views:ModSelectionView DataContext="{Binding ModSelection}"/>
            </TabItem>
            <TabItem Header="Preview">
                <views:TranslationPreviewView DataContext="{Binding TranslationPreview}"/>
            </TabItem>
            <TabItem Header="Glossary">
                <views:GlossaryView DataContext="{Binding Glossary}"/>
            </TabItem>
            <TabItem Header="Settings">
                <views:SettingsView DataContext="{Binding Settings}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
