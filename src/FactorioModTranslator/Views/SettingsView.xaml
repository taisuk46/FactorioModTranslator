<UserControl x:Class="FactorioModTranslator.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:FactorioModTranslator.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:StringToBoolConverter x:Key="StringToBoolConverter"/>
    </UserControl.Resources>
    
    <Grid Margin="20">
        <StackPanel MaxWidth="600" HorizontalAlignment="Left" Width="600">
            <TextBlock Text="Settings" FontSize="18" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,20"/>

            <TextBlock Text="Translation Engine" Foreground="{StaticResource MutedTextBrush}"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,20">
                <RadioButton Content="DeepL" IsChecked="{Binding SelectedEngine, Converter={StaticResource StringToBoolConverter}, ConverterParameter=DeepL}" Foreground="{StaticResource TextBrush}" Margin="0,0,20,0"/>
                <RadioButton Content="Google Translate" IsChecked="{Binding SelectedEngine, Converter={StaticResource StringToBoolConverter}, ConverterParameter=GoogleTranslate}" Foreground="{StaticResource TextBrush}"/>
            </StackPanel>

            <TextBlock Text="DeepL API Key" Foreground="{StaticResource MutedTextBrush}"/>
            <TextBox Text="{Binding DeepLApiKey}" Margin="0,5,0,20"/>

            <TextBlock Text="Google Translate API Key" Foreground="{StaticResource MutedTextBrush}"/>
            <TextBox Text="{Binding GoogleApiKey}" Margin="0,5,0,20"/>

            <TextBlock Text="Factorio Installation Path" Foreground="{StaticResource MutedTextBrush}"/>
            <Grid Margin="0,5,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding FactorioPath}"/>
                <Button Grid.Column="1" Content="..." Command="{Binding BrowseFactorioPathCommand}" Width="40" Margin="5,0,0,0"/>
            </Grid>

            <Button Content="Save Settings" Command="{Binding SaveCommand}" Width="150" HorizontalAlignment="Left" Margin="0,10,0,0" Background="{StaticResource AccentBrush}"/>
        </StackPanel>
    </Grid>
</UserControl>
