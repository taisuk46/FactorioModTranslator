{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FactorioModTranslator",
  "version": "0.1.0",
  "identifier": "com.factoriomodtranslator.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Factorio Mod Translator",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Japanese", "English"],
        "displayLanguageSelector": false
      }
    }
  }
}
